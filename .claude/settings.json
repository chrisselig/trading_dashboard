{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-commit.sh",
            "timeout": 60,
            "statusMessage": "Running pre-commit checks (ruff + pytest)..."
          }
        ]
      }
    ]
  }
}
